cat > .gitignore << 'EOF'
# Виртуальные окружения
venv/
env/
.venv/

# Кэш Python
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Секретные конфигурации (ЗДЕСЬ ЛЕЖАТ ПАРОЛИ)
../../.env
.env.local

# Данные Docker-контейнеров
pg_data/
postgres_data/
.docker-volumes/

# Пользовательские загрузки
media/
/media/

# Временные файлы операционных систем
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# SQLite база данных (для разработки)
db.sqlite3

# Логи
*.log
EOF